{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "navplot2",
  "compatibility_date": "2026-06-03",

  "workers_dev": false,
  "preview_urls": false,

  "assets": {
    "directory": "./build"
  },

  "build": {
    "command": "uv run build.py build",
  },

  "routes": [
    {
      "pattern": "navplot_test.asselect.uk",
      "custom_domain": true,
    }
  ],

  "secrets": {
    "required": [
      "NATS_USER", "NATS_PASSWORD", "DISCORD_WEB_HOOK"
    ]
  }
}
